# ── Solana ────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_NETWORK=devnet
# Options: devnet | mainnet-beta | testnet

# ── Admin ─────────────────────────────────────────────────────
# Public — shown in the UI ("connect this wallet to access admin panel").
NEXT_PUBLIC_ADMIN_WALLET=YOUR_ADMIN_WALLET_PUBLIC_KEY
# Server-side check — must match NEXT_PUBLIC_ADMIN_WALLET. Kept separate so the
# admin API can't be tricked by a client setting NEXT_PUBLIC_ADMIN_WALLET to
# their own wallet at build time.
ADMIN_WALLET=YOUR_ADMIN_WALLET_PUBLIC_KEY

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
